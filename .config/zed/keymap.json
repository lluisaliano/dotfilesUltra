[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-t": [
        "workspace::NewTerminal",
        {}
      ],
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-w": "file_finder::Toggle",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-q": "terminal_panel::Toggle",
    },
  },
  {
    "context": "SettingsWindow",
    "bindings": {
      "ctrl-w": null,
    },
  },
  {
    "context": "RulesLibrary",
    "bindings": {
      "ctrl-w": null,
    },
  },
  {
    "bindings": {
      "ctrl-k ctrl-o": "workspace::Open",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-b": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "space o": "editor::NewlineBelow",
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "space O": "editor::NewlineAbove",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-w": null,
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-w c": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false,
        },
      ],
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-h": "editor::SwitchSourceHeader",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-/": ["workspace::SendKeystrokes", "~"],
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-r": "project_symbols::Toggle",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-g": [
        "task::Spawn",
        { "task_name": "Start Lazygit", "reveal_target": "center" },
      ],
    },
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "space /": "pane::DeploySearch"
    }
  },
  {
    "context": "(!Editor && !Terminal)",
    "bindings": {
      "space /": "pane::DeploySearch"
    }
  },
  {
    "context": "(Editor && mode == full)",
      "bindings": {
      "alt-e": "outline::Toggle"
    }
  },
  {
    "context": "vim_mode == normal",
      "bindings": {
      "\"\"": "vim::ToggleRegistersView"
    }
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "\"": "vim::ToggleRegistersView"
    }
  }
]
